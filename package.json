{
  "name": "@skastr0/probe",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "probe": "bun run src/cli/main.ts",
    "serve": "bun run src/cli/main.ts serve",
    "doctor": "bun run src/cli/main.ts doctor",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck",
    "build": "bun scripts/build.ts",
    "install:local": "bun scripts/install.ts",
    "transport-spike": "bun run src/spikes/runner-transport/benchmark.ts",
    "lldb-bridge-spike": "bun run src/spikes/lldb-python-bridge/validate.ts",
    "coexistence-spike": "bun run src/spikes/concurrent-attachment-coexistence/validate.ts",
    "verify": "bun run typecheck && bun run test && bun run build"
  },
  "files": [
    "src",
    "ios",
    "!ios/**/.build",
    "!ios/**/xcuserdata",
    "!ios/**/*.xcuserstate",
    "README.md"
  ],
  "dependencies": {
    "effect": "^3.21.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "^6.0.2"
  },
  "license": "MIT",
  "description": "iOS app inspection and automation CLI for development workflows.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skastr0/probe.git"
  },
  "homepage": "https://github.com/skastr0/probe#readme",
  "bugs": {
    "url": "https://github.com/skastr0/probe/issues"
  }
}
